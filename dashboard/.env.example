# ===================================================================
# Dashboard environment variables — Vercel deployment reference
# ===================================================================
#
# This is the complete list of every env var the dashboard reads
# (via process.env.*). Add ALL of these to your Vercel project for
# every environment you care about (Production AND Preview is
# recommended; Development is optional unless you want preview
# branches to share the same secrets).
#
# Vercel path: Project Settings → Environment Variables → Add New
#
# After adding, you MUST trigger a redeploy for the new values to be
# picked up by the running build:
#   Vercel → Deployments → ... menu on latest → Redeploy
#
# Local dev: copy this file to `.env.local` (gitignored) and fill in
# the values from 1Password / your password manager. NEVER commit
# `.env.local`.
#
# -------------------------------------------------------------------


# ─── Supabase (REQUIRED — without these the dashboard won't boot) ───

# Public URL of your Supabase project, e.g. https://abcdefg.supabase.co
# Where to get it: Supabase Dashboard → Project Settings → API → Project URL
# Used by:        all SSR + client Supabase queries (every page in the dashboard)
# Format:         https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Anonymous public API key for your Supabase project (the long JWT
# that starts with `eyJ`). This is safe to expose to the browser —
# RLS policies in Postgres are what actually gate row access.
# Where to get it: Supabase Dashboard → Project Settings → API → Project API keys → `anon` `public`
# Used by:        all SSR + client Supabase queries
# Format:         Long JWT starting with `eyJ` (~200 chars)
NEXT_PUBLIC_SUPABASE_ANON_KEY=


# ─── Credential vault (REQUIRED — creator account-request form breaks without this) ───

# Symmetric encryption key for the credential vault that stores
# creator-submitted Blotato passwords. Used by `dashboard/src/lib/
# credential-vault.ts` via scryptSync + AES-256-GCM to encrypt the
# password field before it lands in `creator_account_requests`.
#
# IMPORTANT: this value must be STABLE across environments. Rotating
# it would orphan every existing encrypted row (decryption would
# silently fail). When setting up Vercel for the first time, copy
# the same value that's already in your local `.env.local`. If you
# don't have one yet, generate fresh:
#   openssl rand -base64 48
#
# Must be at least 16 characters. The vault throws on shorter values.
# Used by:        creator account-request flow (creator portal → admin approval)
# What breaks:    "Server isn't configured to accept passwords right now"
#                 surfaces in the creator's add-account form.
CREDENTIAL_VAULT_KEY=


# ─── Gemini API (REQUIRED for "Distill style" button on campaign Edit page) ───

# Google AI Studio API key for Gemini. The dashboard uses this for
# the style-distillation server action on the campaign Edit page —
# given a campaign's training images, Gemini extracts the distilled
# style guide that gets injected into every image + caption prompt.
# Where to get it: https://aistudio.google.com/apikey
# Used by:        dashboard/src/app/(dashboard)/campaigns/[slug]/edit/actions.ts:359
# What breaks:    "Distill style" button on Edit page returns an error.
#                 (Style distillation is a one-time per-campaign action;
#                 if you don't use it, this is optional.)
# Format:         Starts with `AIzaSy` (~40 chars)
# Note:           This is the SAME key the pipeline uses for image generation —
#                 reuse the same value across `dashboard/.env.local` and the
#                 root `.env.local` on the Mac mini.
GEMINI_API_KEY=


# ─── Resend (REQUIRED for Reports tab "Send test digest" email) ───

# Resend API key for transactional email sending. Used by the Reports
# tab's "Send test digest" button and (in future) the daily digest
# cron.
# Where to get it: https://resend.com/api-keys
# Used by:        dashboard/src/app/(dashboard)/campaigns/[slug]/reports/actions.ts:157,198
# What breaks:    "Send test digest" returns an error. Daily digest
#                 cron (not yet wired) won't fire.
# Format:         Starts with `re_` (~32 chars)
RESEND_API_KEY=


# ─── Resend "from" address (OPTIONAL — has a default fallback) ───

# The "From:" address used when sending digest emails. Must be a
# verified sender on your Resend account (either a domain you've
# verified, or the default onboarding sandbox).
# Default if unset: `onboarding@resend.dev` (Resend's sandbox sender,
#                   fine for testing but rate-limited)
# For production:   set to something like `digests@yourdomain.com`
#                   AFTER verifying that domain in Resend.
# Format:           Either `name@domain.com` or `Display Name <name@domain.com>`
RESEND_FROM=


# ===================================================================
# Anything that DOESN'T need to be in Vercel
# ===================================================================
#
# The following env vars are used by the PIPELINE (Mac mini) but
# NOT by the dashboard. They live in the repo-root `.env.local`,
# NOT in `dashboard/.env.local` and NOT in Vercel:
#
#   VIRLO_API_KEY              — Virlo trend research (root)
#   BLOTATO_API_KEY            — TikTok posting via Blotato (root)
#   SCRAPECREATORS_API_KEY     — TikTok metrics (root)
#   AUTO_FIX_GEMINI            — opt-in flag for Gemini-powered auto-fix proposals (root, off by default)
#   SLACK_ALERT_WEBHOOK        — optional Slack alerts (root)
#
# Adding pipeline keys to Vercel does no harm but provides no value —
# the pipeline doesn't run on Vercel, it runs on the Mac mini.
